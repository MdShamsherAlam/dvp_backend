# Node modules
node_modules/
**/node_modules/

# Build output
dist/
**/dist/

# Local env files
.env
.env.*
.env.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
.history/

# Temp files
tmp/
temp/

# Coverage
coverage/

# Uploaded files or runtime storage
uploads/
**/uploads/

# Docker
docker-compose.override.yml

# Misc
*.tgz
*.zip

# Ignore compiled JS in case someone accidentally commits
**/*.js
**/*.map

# Keep important config examples tracked
!.env.example
